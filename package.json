{
  "name": "openclaw-onlyonebot",
  "version": "0.1.17",
  "description": "Minimal OpenClaw OneBot channel plugin",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "install.sh"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./setup-entry.ts",
    "runtimeSetupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "onlyonebot",
      "label": "Only OneBot",
      "selectionLabel": "Only OneBot (HTTP API)",
      "docsPath": "/channels/onlyonebot",
      "blurb": "Minimal OneBot channel plugin",
      "aliases": [
        "onebot",
        "ob"
      ]
    }
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  }
}

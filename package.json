{
  "name": "@openclaw/onlyonebot",
  "version": "0.1.7",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "description": "占位 OneBot 渠道插件（验证 OpenClaw 安装流程）",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "scripts",
    "src",
    "index.ts",
    "setup-entry.ts",
    "preload.cjs",
    "tsconfig.json",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "id": "openclaw-onlyonebot",
    "extensions": ["./preload.cjs"],
    "setupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "onlyonebot",
      "label": "Only OneBot"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "postinstall": "node scripts/postinstall-link-sdk.js"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.9.3"
  }
}

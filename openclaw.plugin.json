{
  "id": "openclaw-onlyonebot",
  "name": "Only OneBot",
  "description": "占位 OneBot 渠道插件，用于验证 OpenClaw 插件安装与 Channel 配置界面",
  "channels": ["onlyonebot"],
  "extensions": ["./preload.cjs"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  },
  "channelConfigs": {
    "onlyonebot": {
      "preferOver": ["onlyonebot"],
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "token": {
            "type": "string",
            "description": "占位 token，任意非空字符串即可通过验证"
          }
        },
        "required": ["token"]
      },
      "uiHints": {
        "token": {
          "label": "访问令牌（占位）",
          "sensitive": true,
          "placeholder": "stub-token"
        }
      }
    }
  }
}
